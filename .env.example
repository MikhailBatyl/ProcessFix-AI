# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=processfix
POSTGRES_PASSWORD=changeme
POSTGRES_DB=processfix
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── ClickHouse ─────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=processfix
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── MinIO (S3) ─────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=processfix-raw
MINIO_BUCKET_ARTIFACTS=processfix-artifacts
MINIO_SECURE=false

# ── dbt ────────────────────────────────────────────────
DBT_TARGET=dev
DBT_PROFILES_DIR=/dbt

# ── Airflow ────────────────────────────────────────────
AIRFLOW_TZ=Asia/Novosibirsk

# ── Analytics ──────────────────────────────────────────
# "raw"  — MVP-режим: CH event_logs + PG norms (pandas join)
# "marts" — Platform-режим: CH mart_daily_losses (dbt-витрина)
ANALYTICS_SOURCE=raw

# ── App ────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
